# Supabase — copy to ".env" and fill in from your project's
# Settings → API page. Safe to expose (RLS protects the data).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET — used only by the seed script (scripts/seed.mjs). NEVER commit this,
# never prefix with VITE_. Found under Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
